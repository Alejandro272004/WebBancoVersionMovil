rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── USUARIOS ──────────────────────────────────────────────────────────────
    // Cualquier usuario autenticado puede leer perfiles (necesario para buscar
    // destinatarios por IBAN o email en transferencias y huchas).
    // Solo el propio usuario puede modificar su documento.
    match /usuarios/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Nadie puede borrar cuentas desde el cliente

      // ── MOVIMIENTOS (subcolección privada) ──────────────────────────────────
      // Solo el dueño puede leer y escribir sus propios movimientos.
      // Las transacciones de huchas y transferencias escriben aquí con privilegios
      // de servidor (runTransaction), por lo que el dueño también debe poder crear.
      match /movimientos/{movId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if false; // Los movimientos son inmutables
        allow delete: if false;
      }

      // ── CALENDARIO (subcolección privada) ───────────────────────────────────
      match /calendario/{pagoId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── HUCHAS COMPARTIDAS ────────────────────────────────────────────────────
    // Solo pueden acceder los miembros listados en el array 'miembros'.
    // Solo el creador puede eliminar la hucha.
    match /huchas_compartidas/{huchaId} {
      allow read:   if request.auth != null &&
                       request.auth.uid in resource.data.miembros;
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.creador;
      allow update: if request.auth != null &&
                       request.auth.uid in resource.data.miembros;
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.creador;
    }

    // ── TRANSFERENCIAS PROGRAMADAS ────────────────────────────────────────────
    // El emisor puede crear y eliminar. Emisor o destinatario pueden leer.
    match /transferencias_programadas/{txId} {
      allow read:   if request.auth != null &&
                       (request.auth.uid == resource.data.emisorUid ||
                        resource.data.destinatarioEmail == request.auth.token.email);
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.emisorUid;
      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.emisorUid;
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.emisorUid;
    }
  }
}
